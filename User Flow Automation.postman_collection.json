    {
      "name": "Login (extract token)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Debug logs (preserved)",
              "console.log(\"Resolved URL:\", pm.request.url.toString());",
              "",
              "const apiKey = pm.request.headers.get(\"x-api-key\");",
              "console.log(\"x-api-key header present?:\", Boolean(apiKey));",
              "console.log(\"x-api-key header length:\", apiKey ? apiKey.length : 0);",
              "",
              "console.log(\"Status:\", pm.response.code);",
              "console.log(\"Response body:\", pm.response.text());",
              "",
              "// Token extraction + tests",
              "let jsonData;",
              "try {",
              "  jsonData = pm.response.json();",
              "} catch (e) {",
              "  console.warn(\"Response is not valid JSON\");",
              "  jsonData = null;",
              "}",
              "",
              "const token = jsonData?.token;",
              "if (token) {",
              "  pm.environment.set('token', token);",
              "  console.log(\"Token saved to environment variable 'token'\");",
              "} else {",
              "  console.warn(\"Token not found at response.token\");",
              "}",
              "",
              "pm.test(\"Status code is 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Token exists in response\", function () {",
              "  pm.expect(token, \"response.token\").to.be.ok;",
              "});",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
